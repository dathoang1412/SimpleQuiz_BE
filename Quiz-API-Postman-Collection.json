                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"text\": \"What is Express.js?\",\n    \"options\": [\"A framework\", \"A database\", \"A language\", \"An operating system\"],\n    \"keywords\": [\"express\", \"nodejs\", \"framework\"],\n    \"correctAnswerIndex\": 0\n}"
