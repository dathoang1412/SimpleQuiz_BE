                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.token) {",
                                    "    pm.environment.set(\"user_token\", jsonData.token);",
                                    "    pm.environment.set(\"user_id\", jsonData.user._id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
